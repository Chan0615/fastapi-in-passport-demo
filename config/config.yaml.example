# ========== 系统根配置（非数据库连接类）==========
system_root:
  ldap: http://127.0.0.1:8080/api/v1/ldap/login
  download_dir: download/
  upload_dir: upload/

# ========== 应用配置 ==========
app:
  name: FastAPI Template
  version: 0.1.0
  debug: true

# ========== 安全配置 ==========
security:
  secret_key: change-me-in-production
  cors_origins:
    - "*"
  cookie_domain: .ops.com    # SSO 域名根域，如 .ops.com（所有 *.ops.com 系统共享登录态）

# ========== 外部 API 配置 ==========
external_api:
  example_base_url: https://api.example.com
  example_api_key: your-api-key

# ========== Passport 认证中心 ==========
# 通过内网域名访问（需配置 DNS 解析到 passport 服务器 IP）
passport_url: http://fastapi-passport.ops.com:8888

# ========== 引导数据库配置 ==========
# 其他 MySQL/Redis/Mongo 连接信息均存入引导数据库对应的
# mysql_info / redis_info / mongo_info 表中，通过 API 读取。
# 复制本文件为 config.yaml 后填写真实地址（config.yaml 已加入 .gitignore，勿提交）
mysql:
  system_default_db:
    db_addr: 10.225.138.121     # 真实 MySQL 服务器 IP
    db_port: 3306
    db_user: root
    db_password: your_password
    db_name: kefu_fastapi_ant_demo
    app_env: dev
